configuration {
    modi:                       "drun,run,window";
    show-icons:                 true;
    drun-display-format:        "{name}";
    window-format:              "{w} · {c} · {t}";
    display-drun:               "  Apps";
    display-run:                "  Run";
    display-window:             "  Windows";
    icon-theme:                 "Papirus-Dark";
    terminal:                   "kitty";
}

@import "shadow-dragon.rasi"